# Per-site .env — copy to .env and fill in real values before running the deploy script.
# Never commit the populated .env (it has secrets). The .env.example is the canonical
# list; if you add a new env var anywhere, add it here with a comment.

# ─── Identity ─────────────────────────────────────────────────────
DOMAIN=newsite.example.com                # production hostname (no protocol)
SPA_URL=https://newsite.example.com       # full SPA URL — used for CORS + REST CORS allowlist
BRAND_NAME=My New Brand                   # appears in emails, SEO title, page header

# ─── SiteGround SSH ───────────────────────────────────────────────
SSH_HOST=newsite-sg-host                  # alias from ~/.ssh/config
WP_PATH=/home/customer/www/${DOMAIN}/public_html

# ─── Optional integrations (leave blank to skip) ──────────────────
EASYPOST_API_KEY=
GOOGLE_MAPS_API_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Marketing / analytics — admin can also set these via WCHS Settings UI later.
GTM_ID=
META_PIXEL_ID=
TIKTOK_PIXEL_ID=
PINTEREST_TAG_ID=
KLAVIYO_PUBLIC_KEY=
OMNISEND_BRAND_ID=
CLARITY_PROJECT_ID=
HOTJAR_SITE_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=
